{
  "max_concurrent_agents": 6,
  "default_model": "sonnet",
  "agents": {
    "architect": { "enabled": true, "model": null },
    "developer": { "enabled": true, "model": null },
    "tester": { "enabled": true, "model": null },
    "reviewer": { "enabled": true, "model": null }
  },
  "autonomous": false,
  "auto_review": true,
  "auto_merge": false,
  "dispatch": {
    "isolation_mode": "auto"
  },
  "ticket_id_prefix": "PA",
  "triage": {
    "auto_fix": true,
    "auto_verify": true,
    "default_priority": "P1",
    "max_concurrent_triage": 4
  },
  "wiki": {
    "enabled": true,
    "vault_path": "~/projects/obsidian/project-agent",
    "auto_ingest": true,
    "auto_query": true,
    "auto_lint_interval": null,
    "patterns": {
      "enabled": true
    }
  }
}
